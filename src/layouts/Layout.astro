---
const { title = 'Domac Accesos S.L. — Domotización de accesos municipales' } = Astro.props
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Domac Accesos S.L. — Soluciones de domotización, gestión de accesos y reservas para ayuntamientos y servicios públicos." />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      background: #0a0a0a;
      color: #f5f5f5;
      line-height: 1.6;
    }
    a { color: inherit; text-decoration: none; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
